extends layout

block content
  .col-md-12(style='margin-bottom:4%')
    .card.card-default
      .card-header
        h5.card-title SmartNodes
      .card-body
        if smartnodes.length == 0
          .alert.alert-warning No SmartNodes found.
        else
          .table-responsive
            table.table.table-hover.table-bordered.table-striped
              thead
                tr
                  th Status
                  th Address
                  th Protocol
                  th Payee
                  th Last Seen
                  th Active
                  th Last Paid
                  th Outpoint
              tbody
                each node in smartnodes
                  tr
                    td
                      if node.status == 'ENABLED'
                        span.badge.badge-success #{node.status}
                      else if node.status == 'PRE_ENABLED'
                        span.badge.badge-info #{node.status}
                      else if node.status == 'UPDATE_REQUIRED'
                        span.badge.badge-warning #{node.status}
                      else
                        span.badge.badge-secondary #{node.status}
                    td #{node.address}
                    td #{node.protocol}
                    td
                      if node.payee
                        a(href='/address/' + node.payee) #{node.payee}
                    td
                      if node.lastSeen > 0
                        script.
                          document.write(new Date(!{node.lastSeen} * 1000).toLocaleString())
                      else
                        | -
                    td
                      - var active = node.activeSeconds || 0
                      - var days = Math.floor(active / 86400)
                      - var hours = Math.floor((active % 86400) / 3600)
                      - var minutes = Math.floor((active % 3600) / 60)
                      if days > 0
                        | #{days}d #{hours}h
                      else if hours > 0
                        | #{hours}h #{minutes}m
                      else
                        | #{minutes}m
                    td
                      if node.lastPaidTime > 0
                        script.
                          document.write(new Date(!{node.lastPaidTime} * 1000).toLocaleString())
                      else if node.lastPaidBlock > 0
                        | Block #{node.lastPaidBlock}
                      else
                        | -
